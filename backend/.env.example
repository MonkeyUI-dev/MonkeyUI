# Django settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=monkeyui_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Language
LANGUAGE_CODE=en-us

# =============================================================================
# Redis (for Celery and Cache)
# =============================================================================
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Set the default provider (openai, gemini, openrouter, qwen, kimi)
# DEFAULT_LLM_PROVIDER=openai

# OpenAI Configuration
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=  # Optional, for compatible APIs

# Google Gemini Configuration
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash

# OpenRouter Configuration
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=openai/gpt-4o
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Alibaba Qwen Configuration
# QWEN_API_KEY=your-qwen-api-key
# QWEN_MODEL=qwen-vl-max
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Moonshot Kimi Configuration
# KIMI_API_KEY=your-kimi-api-key
# KIMI_MODEL=moonshot-v1-32k-vision-preview
# KIMI_BASE_URL=https://api.moonshot.cn/v1
