# Django settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/monkeyui_dev

# CORS
# Add your frontend domains (comma-separated, no spaces)
# Example: CORS_ALLOWED_ORIGINS=https://your-domain.com,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Language
LANGUAGE_CODE=en-us

# =============================================================================
# Redis (for Celery and Cache)
# =============================================================================
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Set the default provider (gemini, openrouter, qwen)
# DEFAULT_LLM_PROVIDER=gemini

# Google Gemini Configuration
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-3-pro-preview

# OpenRouter Configuration
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=openai/gpt-4o
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Alibaba Qwen Configuration
# QWEN_API_KEY=your-qwen-api-key
# QWEN_MODEL=qwen-vl-max
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# =============================================================================
# File Storage Configuration
# =============================================================================
# Storage backend for user uploads (design system images, etc.)
# Options: 'local' (default for development) or 's3' (recommended for production)
FILE_STORAGE_BACKEND=local

# Local Storage Settings (used when FILE_STORAGE_BACKEND=local)
# Files will be stored in MEDIA_ROOT directory
# MEDIA_URL=/media/
# MEDIA_ROOT=./media

# S3 Storage Settings (used when FILE_STORAGE_BACKEND=s3)
# Required parameters (must be set when using S3):
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
#
# Optional parameters (have defaults, can be omitted):
# AWS_S3_REGION_NAME=us-east-1                    # Default: us-east-1
# AWS_S3_CUSTOM_DOMAIN=your-bucket-name.s3.amazonaws.com  # Default: None (use S3 URL)
# AWS_S3_CACHE_CONTROL=max-age=86400              # Default: max-age=86400
# AWS_DEFAULT_ACL=private                         # Default: private
# AWS_QUERYSTRING_AUTH=True                       # Default: True (use signed URLs)
# AWS_S3_FILE_OVERWRITE=False                     # Default: False (keep unique filenames)
# AWS_S3_SIGNATURE_VERSION=s3v4                   # Default: s3v4
# AWS_S3_ENDPOINT_URL=                            # Default: None (only for S3-compatible services)

# S3-Compatible Storage Settings (CloudFlare R2, MinIO, Backblaze B2, etc.)
# For non-AWS S3-compatible services, set AWS_S3_ENDPOINT_URL to the service endpoint
#
# CloudFlare R2 example:
# AWS_ACCESS_KEY_ID=your-r2-access-key-id
# AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
# AWS_S3_REGION_NAME=auto
#
# MinIO example:
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_STORAGE_BUCKET_NAME=monkeyui-media
# AWS_S3_ENDPOINT_URL=http://localhost:9000
#
# Backblaze B2 example:
# AWS_ACCESS_KEY_ID=your-b2-key-id
# AWS_SECRET_ACCESS_KEY=your-b2-application-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com
